# ============================================================
# ARQUIVO DE CONFIGURAÇÕES — RENOMEIE PARA .env
# ============================================================
# Este arquivo guarda informações secretas do sistema.
# NUNCA suba este arquivo para o GitHub!

# Conexão com o banco de dados MongoDB
# Substitua pela sua string de conexão do MongoDB Atlas
MONGODB_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@cluster0.xxxxx.mongodb.net/clinica?retryWrites=true&w=majority

# Chave secreta para gerar tokens JWT (pode ser qualquer texto longo)
JWT_SECRET=minha_chave_super_secreta_clinica_2024

# Porta onde o servidor vai rodar
PORT=3001

# Chave da API do clima — obtenha grátis em openweathermap.org
OPENWEATHER_API_KEY=SUA_CHAVE_AQUI
